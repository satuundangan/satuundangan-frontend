{
  "name": "invitation-project",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "postbuild": "node -e \"if(!process.env.VERCEL) process.exit(require('child_process').spawnSync('npm', ['run', 'prerender'], {stdio: 'inherit', shell: true}).status)\"",
    "preview": "vite preview",
    "prerender": "node scripts/prerender.js",
    "test": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test tests/p0-smoke.mocked.spec.js --project=mocked",
    "test:e2e:mocked": "playwright test --project=mocked",
    "test:e2e:prod": "node scripts/run-playwright-prod.js",
    "test:e2e:prod:write": "node scripts/run-playwright-prod-write.js",
    "lint": "eslint . --fix",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.8",
    "@vueuse/core": "^13.4.0",
    "axios": "^1.11.0",
    "idb-keyval": "^6.2.2",
    "pinia": "^3.0.3",
    "slugify": "^1.6.9",
    "sweetalert2": "^11.22.2",
    "vue": "^3.5.13",
    "vue-advanced-cropper": "^2.8.9",
    "vue-router": "^4.5.0",
    "vue-toastification": "^2.0.0-rc.5",
    "wavesurfer.js": "^7.12.7",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@playwright/test": "^1.59.1",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.22.0",
    "eslint-plugin-vue": "~10.0.0",
    "globals": "^16.0.0",
    "jsdom": "^29.0.0",
    "postcss": "^8.5.4",
    "prettier": "3.5.3",
    "tailwindcss": "^4.1.8",
    "vite": "^6.2.4",
    "vite-plugin-vue-devtools": "^7.7.2",
    "vitest": "^4.1.0"
  }
}
