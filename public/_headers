/*
  Cache-Control: public, max-age=0, must-revalidate

# Cache compiled JS/CSS and static images from Vite
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Cache static audio files
/audio/*
  Cache-Control: public, max-age=31536000, immutable

# Cache static background designs
/background/*
  Cache-Control: public, max-age=31536000, immutable

